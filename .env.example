# Manthan — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM (Vultr Serverless Inference) -------------------------------------
# Manthan reaches the upstream LLM through Vultr Serverless Inference's
# OpenAI-compatible chat completions endpoint. Get a key by enabling
# Serverless Inference in your Vultr account:
#   https://my.vultr.com/inference/
# Hackathon participants get $200 in credits (first-come, first-served).
VULTR_API_KEY=your_key_here

# Primary model. Manthan defaults to MiniMax M2.7 (agentic, native OpenAI
# tool-calling, strong on multi-step reasoning). The "-normalize" suffix
# tells Vultr to canonicalise reasoning_content / tool_call_id quirks.
VULTR_MODEL=MiniMaxAI/MiniMax-M2.7-normalize

# Fallback cascade — tried in order if primary is rate-limited / fails.
# Default uses Qwen3.6-27B (small, fast, cheap retry).
VULTR_FALLBACK_MODELS=["Qwen/Qwen3.6-27B-FP8"]

VULTR_BASE_URL=https://api.vultrinference.com/v1

# --- Layer 2 agent overrides (optional) -----------------------------------
# By default the agent inherits VULTR_* above. Set these to use a
# different model/key/url specifically for Layer 2 reasoning.
# AGENT_MODEL=MiniMaxAI/MiniMax-M2.7-normalize
# AGENT_VULTR_API_KEY=
# AGENT_VULTR_BASE_URL=

# --- DuckDB ---------------------------------------------------------------
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4
DUCKDB_TEMP_DIRECTORY=/tmp/duckdb

# --- Storage --------------------------------------------------------------
DATA_DIRECTORY=./data
MAX_UPLOAD_SIZE_MB=500

# --- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
LOG_FORMAT=console
